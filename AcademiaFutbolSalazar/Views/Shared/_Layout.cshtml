<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AcademiaFutbolSalazar</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AcademiaFutbolSalazar.styles.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body style="background-color:#f5f7fa; color:#222; min-height:100vh;">

    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white shadow-sm mb-3"
             style="border-bottom:2px solid #C8102E;">

            <div class="container-fluid">

                <a class="navbar-brand d-flex align-items-center gap-2"
                   asp-area="" asp-controller="Home" asp-action="Index">

                    <img src="/images/logo.png" style="height:50px; width:50px; object-fit:contain;" />

                    <div style="border-left: 2px solid #C8102E; padding-left: 10px;">
                        <div style="color:#C8102E; font-weight:bold; font-size:0.85rem; line-height:1.1;">ACADEMIA SALAZAR </div>
                        <div style="color:#001f8f; font-weight:bold; font-size:1.1rem; line-height:1.1;">FUTBOL ELITE</div>
                    </div>

                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    <ul class="navbar-nav flex-grow-1 ms-3">
                        <li class="nav-item">
                            <a class="nav-link fw-semibold" style="color:#001f8f;"
                               asp-area="" asp-controller="Home" asp-action="Index">
                                🏠 Home
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link fw-semibold" style="color:#001f8f;"
                               asp-area="" asp-controller="Entrenador" asp-action="Index">
                                🏋️ Entrenadores
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link fw-semibold" style="color:#001f8f;"
                               asp-area="" asp-controller="Estudiante" asp-action="Index">
                                ⚽ Estudiantes
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link fw-semibold" style="color:#001f8f;"
                               asp-area="" asp-controller="Pago" asp-action="Index">
                                💰 Pagos
                            </a>
                        </li>
                    </ul>

                    <div class="d-flex align-items-center gap-3">

                        <div class="d-flex align-items-center gap-2">
                            <div style="width:45px; height:45px; border-radius:50%; border:2px solid #C8102E; overflow:hidden; background:white; box-shadow:0 2px 8px rgba(0,0,0,0.15);">
                                <img src="@Context.Session.GetString("Imagen")"
                                     style="width:100%; height:100%; object-fit:cover; object-position:center top;" />
                            </div>
                            <div>
                                <div style="color:#001f8f; font-weight:600; font-size:0.95rem; line-height:1.1;">
                                    @Context.Session.GetString("Usuario")
                                </div>
                                <div style="color:#C8102E; font-size:0.8rem;">
                                    @Context.Session.GetString("Rol")
                                </div>
                            </div>
                        </div>

                        <a href="/Login/Logout" class="btn fw-bold"
                           style="background:#C8102E; color:white; border-radius:10px; padding:8px 16px;">
                            🔒 Cerrar Sesión
                        </a>

                    </div>

                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid px-0">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>