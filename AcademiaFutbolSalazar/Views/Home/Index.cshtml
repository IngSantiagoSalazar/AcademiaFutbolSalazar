@{
    ViewData["Title"] = "Academia de Fútbol Salazar";
}

<div class="container-fluid px-0">

    <!-- BANNER -->
    <div style="position:relative; height:350px; overflow:hidden;">
        <img src="/images/banner.png"
             style="width:100%; height:100%; object-fit:cover; object-position:center center;" />
        <div style="position:absolute; top:0; left:0; right:0; bottom:0;
            background:linear-gradient(90deg, rgba(0,31,143,0.85), rgba(200,16,46,0.3));
            display:flex; align-items:center; padding-left:60px;">
            <div>
                <h1 class="fw-bold" style="color:white; font-size:3rem; text-shadow:2px 2px 8px rgba(0,0,0,0.5);">
                    Academia Fútbol Salazar
                </h1>
                <p style="color:#FFD700; letter-spacing:4px; font-size:1rem;">
                    DISCIPLINA · PASIÓN · FUTURO
                </p>
                <span style="color:white; font-size:1rem;">
                    Bienvenido, <strong style="color:#FFD700;">@Context.Session.GetString("Usuario")</strong>
                </span>
            </div>
        </div>
    </div>

    <!-- LINEA ROJA -->
    <div style="height:5px; background:#C8102E;"></div>

    <!-- FRASE MOTIVACIONAL -->
    <div class="text-center py-4" style="background:white; border-bottom: 1px solid #eee;">
        <h3 class="fw-bold" style="color:#001f8f;">
            ¡DONDE EL TALENTO SE FORJA Y EL FUTURO SE CONSTRUYE!
        </h3>
        <p style="color:#888;">Formamos los cracks del mañana en Pasto, Nariño. ⚽</p>
    </div>

</div>

<div class="container mt-4 mb-2">

    <!-- ESTADISTICAS -->
    <div class="row justify-content-center g-3 mb-5">

        <div class="col-md-3 text-center">
            <div class="p-4 rounded-3 shadow-sm"
                 style="background:white; border-top: 3px solid #001f8f;">
                <h2 class="fw-bold" style="color:#001f8f;">@ViewBag.TotalEntrenadores</h2>
                <p style="color:#888;">🏋️ Entrenadores</p>
            </div>
        </div>

        <div class="col-md-3 text-center">
            <div class="p-4 rounded-3 shadow-sm"
                 style="background:white; border-top: 3px solid #C8102E;">
                <h2 class="fw-bold" style="color:#C8102E;">@ViewBag.TotalEstudiantes</h2>
                <p style="color:#888;">⚽ Estudiantes</p>
            </div>
        </div>

        <div class="col-md-3 text-center">
            <div class="p-4 rounded-3 shadow-sm"
                 style="background:white; border-top: 3px solid #FFD700;">
                <h2 class="fw-bold" style="color:#001f8f;">@ViewBag.TotalPagos</h2>
                <p style="color:#888;">💰 Pagos confirmados</p>
            </div>
        </div>

    </div>

    <!-- CARDS -->
    <div class="row justify-content-center g-4">

        <!-- ENTRENADORES -->
        <div class="col-lg-4 col-md-6">
            <a asp-controller="Entrenador" asp-action="Index" class="text-decoration-none">
                <div class="card border-0 shadow-sm"
                     style="border-radius:16px; overflow:hidden; transition:0.3s;"
                     onmouseover="this.style.transform='translateY(-5px)'; this.style.boxShadow='0 10px 25px rgba(0,0,0,0.1)';"
                     onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='';">
                    <img src="/images/Entrenadores.png"
                         style="height:220px; width:100%; object-fit:cover;" />
                    <div class="card-body p-4" style="border-top: 3px solid #001f8f;">
                        <h4 class="fw-bold" style="color:#001f8f;">🏋️ Entrenadores</h4>
                        <p style="color:#888; font-size:0.95rem;">Administra el equipo técnico de la academia.</p>
                    </div>
                </div>
            </a>
        </div>

        <!-- ESTUDIANTES -->
        <div class="col-lg-4 col-md-6">
            <a asp-controller="Estudiante" asp-action="Index" class="text-decoration-none">
                <div class="card border-0 shadow-sm"
                     style="border-radius:16px; overflow:hidden; transition:0.3s;"
                     onmouseover="this.style.transform='translateY(-5px)'; this.style.boxShadow='0 10px 25px rgba(0,0,0,0.1)';"
                     onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='';">
                    <img src="/images/Estudiantes.jpg"
                         style="height:220px; width:100%; object-fit:cover;" />
                    <div class="card-body p-4" style="border-top: 3px solid #C8102E;">
                        <h4 class="fw-bold" style="color:#C8102E;">⚽ Estudiantes</h4>
                        <p style="color:#888; font-size:0.95rem;">Consulta los jugadores registrados en la academia.</p>
                    </div>
                </div>
            </a>
        </div>

        <!-- PAGOS -->
        <div class="col-lg-4 col-md-6">
            <a asp-controller="Pago" asp-action="Index" class="text-decoration-none">
                <div class="card border-0 shadow-sm"
                     style="border-radius:16px; overflow:hidden; transition:0.3s;"
                     onmouseover="this.style.transform='translateY(-5px)'; this.style.boxShadow='0 10px 25px rgba(0,0,0,0.1)';"
                     onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='';">
                    <img src="/images/Pago.png"
                         style="height:220px; width:100%; object-fit:cover;" />
                    <div class="card-body p-4" style="border-top: 3px solid #FFD700;">
                        <h4 class="fw-bold" style="color:#001f8f;">💰 Pagos</h4>
                        <p style="color:#888; font-size:0.95rem;">Gestiona mensualidades y pagos de estudiantes.</p>
                    </div>
                </div>
            </a>
        </div>

    </div>

    <!-- SEDES -->
    <div class="mt-5 mb-5">
        <h3 class="fw-bold text-center mb-4" style="color:#001f8f;">📍 Nuestras Sedes</h3>
        <div class="row justify-content-center g-3">

            <div class="col-md-3 text-center">
                <div class="p-4 rounded-3 shadow-sm" style="background:white; border-top: 3px solid #001f8f;">
                    <div style="font-size:2rem;">🏟️</div>
                    <h5 class="fw-bold mt-2" style="color:#001f8f;">Estadio Libertad</h5>
                    <p style="color:#888; font-size:0.9rem;">Pasto, Nariño</p>
                </div>
            </div>

            <div class="col-md-3 text-center">
                <div class="p-4 rounded-3 shadow-sm" style="background:white; border-top: 3px solid #C8102E;">
                    <div style="font-size:2rem;">⚽</div>
                    <h5 class="fw-bold mt-2" style="color:#C8102E;">Canchas Seven Eleven</h5>
                    <p style="color:#888; font-size:0.9rem;">Pasto, Nariño</p>
                </div>
            </div>

            <div class="col-md-3 text-center">
                <div class="p-4 rounded-3 shadow-sm" style="background:white; border-top: 3px solid #FFD700;">
                    <div style="font-size:2rem;">🏆</div>
                    <h5 class="fw-bold mt-2" style="color:#001f8f;">Cancha Sintética El Monumental</h5>
                    <p style="color:#888; font-size:0.9rem;">Pasto, Nariño</p>
                </div>
            </div>

            <div class="col-md-3 text-center">
                <div class="p-4 rounded-3 shadow-sm" style="background:white; border-top: 3px solid #001f8f;">
                    <div style="font-size:2rem;">🌿</div>
                    <h5 class="fw-bold mt-2" style="color:#001f8f;">Canchas La Carolina</h5>
                    <p style="color:#888; font-size:0.9rem;">Pasto, Nariño</p>
                </div>
            </div>

        </div>
    </div>

</div>