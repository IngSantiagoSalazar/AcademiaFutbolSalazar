@{
    ViewData["Title"] = "Academia de Fuchivol Salazar";
}

<div class="text-center mt-4">
    <h1 class="display-5" style="color: #FFD700;">Academia Fútbol Salazar</h1>
</div>


<div class="row mt-5 justify-content-center">
    <div class="col-md-3 m-2">
        <a asp-controller="Entrenador" asp-action="Index" class="btn btn-danger btn-lg w-100 p-4">
            Entrenadores
        </a>
    </div>
    <div class="col-md-3 m-2">
        <a asp-controller="Estudiante" asp-action="Index" class="btn btn-danger btn-lg w-100 p-4">
            Estudiantes
        </a>
    </div>
    <div class="col-md-3 m-2">
        <a asp-controller="Pago" asp-action="Index" class="btn btn-danger btn-lg w-100 p-4">
            Pagos
        </a>
    </div>
</div>