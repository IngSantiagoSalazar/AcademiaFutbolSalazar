@model List<AcademiaFutbolSalazar.Models.Pago>

<h2 style="color: #FFD700;">Lista de Pagos</h2>

<table class="table table-dark table-hover mt-3">
    <thead>
        <tr>
            <th style="color: #FFD700;">Estudiante</th>
            <th style="color: #FFD700;">Monto</th>
            <th style="color: #FFD700;">Fecha Pago</th>
            <th style="color: #FFD700;">Método Pago</th>
            <th style="color: #FFD700;">Descripción</th>
            <th style="color: #FFD700;">Pagado</th>
            <th style="color: #FFD700;">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Estudiante?.Nombre @item.Estudiante?.Apellido</td>
                <td>@item.Monto</td>
                <td>@item.FechaPago.ToString("dd/MM/yyyy")</td>
                <td>@item.MetodoPago</td>
                <td>@item.Descripcion</td>
                <td>
                    @if (item.Pagado)
                    {
                        <span class="badge bg-success">Pagado</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Pendiente</span>
                    }
                </td>
                <td>
                    @if (Context.Session.GetString("Especialidad") == "Entrenador General")
                    {
                        <a href="/Pago/Edit/@item.Id"
                           class="btn btn-warning btn-sm">Editar</a>

                        <a href="/Pago/Delete/@item.Id"
                           class="btn btn-danger btn-sm">Eliminar</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>