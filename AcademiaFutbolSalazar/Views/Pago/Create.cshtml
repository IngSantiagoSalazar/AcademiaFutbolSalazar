@model AcademiaFutbolSalazar.Models.Pago

<div class="container mt-4 d-flex justify-content-center">
    <div class="card shadow-sm p-4"
         style="width:100%; max-width:700px; border:none; border-radius:20px; background:white;">

        <div class="text-center mb-4">
            <img src="/images/logo.png" style="width:80px;" class="mb-2" />
            <h2 class="fw-bold" style="color:#001f8f;">Crear Pago</h2>
            <p style="color:#666;">Registra un nuevo pago en la academia</p>
        </div>

        <form asp-action="Create" method="post">

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-semibold" style="color:#001f8f;">Monto</label>
                    <input asp-for="Monto" class="form-control" style="border-radius:12px; padding:12px;" />
                    <span asp-validation-for="Monto" class="text-danger small"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label fw-semibold" style="color:#001f8f;">Fecha Pago</label>
                    <input asp-for="FechaPago" type="date" class="form-control" style="border-radius:12px; padding:12px;" />
                    <span asp-validation-for="FechaPago" class="text-danger small"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-semibold" style="color:#001f8f;">Método Pago</label>
                    <input asp-for="MetodoPago" class="form-control" style="border-radius:12px; padding:12px;" />
                    <span asp-validation-for="MetodoPago" class="text-danger small"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label fw-semibold" style="color:#001f8f;">Mes Pagado</label>
                    <select asp-for="Descripcion" class="form-select" style="border-radius:12px; padding:12px;">
                        <option value="">Seleccione un mes</option>
                        <option value="Enero">Enero</option>
                        <option value="Febrero">Febrero</option>
                        <option value="Marzo">Marzo</option>
                        <option value="Abril">Abril</option>
                        <option value="Mayo">Mayo</option>
                        <option value="Junio">Junio</option>
                        <option value="Julio">Julio</option>
                        <option value="Agosto">Agosto</option>
                        <option value="Septiembre">Septiembre</option>
                        <option value="Octubre">Octubre</option>
                        <option value="Noviembre">Noviembre</option>
                        <option value="Diciembre">Diciembre</option>
                    </select>
                    <span asp-validation-for="Descripcion" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold" style="color:#001f8f;">Estudiante</label>
                <select asp-for="EstudianteId" class="form-select" style="border-radius:12px; padding:12px;">
                    <option value="">Seleccione un estudiante</option>
                    @foreach (var estudiante in ViewBag.Estudiantes)
                    {
                        <option value="@estudiante.Id">@estudiante.Nombre @estudiante.Apellido</option>
                    }
                </select>
            </div>

            <div class="mb-4 form-check">
                <input asp-for="Pagado" class="form-check-input" />
                <label class="form-check-label fw-semibold ms-1" style="color:#001f8f;">Pagado</label>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn fw-bold"
                        style="background:#C8102E; color:white; border-radius:12px; padding:10px 18px;">
                    💾 Guardar
                </button>
                <a href="/Pago" class="btn fw-bold"
                   style="background:#001f8f; color:white; border-radius:12px; padding:10px 18px;">
                    ← Volver
                </a>
            </div>

        </form>
    </div>
</div>