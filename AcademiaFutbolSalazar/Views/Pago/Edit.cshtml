@model AcademiaFutbolSalazar.Models.Pago

<h2 style="color: #FFD700;">Editar Pago</h2>

<form asp-action="Edit" method="post">
    <div asp-validation-summary="All" class="text-danger"></div>

    <input asp-for="Id" type="hidden" />

    <div class="form-group mt-3">
        <label style="color: #FFD700;">Monto</label>
        <input asp-for="Monto" class="form-control bg-dark text-white" />
        <span asp-validation-for="Monto" class="text-danger"></span>
    </div>

    <div class="form-group mt-3">
        <label style="color: #FFD700;">Fecha Pago</label>
        <input asp-for="FechaPago" class="form-control bg-dark text-white" type="date" />
        <span asp-validation-for="FechaPago" class="text-danger"></span>
    </div>

    <div class="form-group mt-3">
        <label style="color: #FFD700;">Método Pago</label>
        <input asp-for="MetodoPago" class="form-control bg-dark text-white" />
        <span asp-validation-for="MetodoPago" class="text-danger"></span>
    </div>

    <div class="form-group mt-3">
        <label style="color: #FFD700;">Mes Pagado</label>
        <select asp-for="Descripcion" class="form-control bg-dark text-white">
            <option value="">Seleccione un mes</option>
            <option value="Enero">Enero</option>
            <option value="Febrero">Febrero</option>
            <option value="Marzo">Marzo</option>
            <option value="Abril">Abril</option>
            <option value="Mayo">Mayo</option>
            <option value="Junio">Junio</option>
            <option value="Julio">Julio</option>
            <option value="Agosto">Agosto</option>
            <option value="Septiembre">Septiembre</option>
            <option value="Octubre">Octubre</option>
            <option value="Noviembre">Noviembre</option>
            <option value="Diciembre">Diciembre</option>
        </select>
        <span asp-validation-for="Descripcion" class="text-danger"></span>
    </div>

    <div class="form-group mt-3">
        <label style="color: #FFD700;">Estudiante</label>
        <select asp-for="EstudianteId" class="form-control bg-dark text-white">
            @foreach (var estudiante in ViewBag.Estudiantes)
            {
                <option value="@estudiante.Id">@estudiante.Nombre @estudiante.Apellido</option>
            }
        </select>
    </div>

    <div class="form-group mt-3">
        <label style="color: #FFD700;">Pagado</label>
        <input asp-for="Pagado" class="form-check-input ms-2" type="checkbox" />
    </div>

    <hr style="border-color: #FFD700;">
    <button type="submit" class="btn btn-danger">Guardar</button>
    <a href="/Pago" class="btn btn-secondary">Volver</a>
</form>