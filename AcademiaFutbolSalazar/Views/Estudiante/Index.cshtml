@model List<AcademiaFutbolSalazar.Models.Estudiante>

<div class="container mt-4">

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }
    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success">@TempData["Mensaje"]</div>
    }

    <div class="text-center mb-4">
        <h1 class="fw-bold" style="color: #FFD700;">⚽ Estudiantes</h1>
        <p style="color:#aaa;">Jugadores de la Academia Fútbol Salazar</p>
        <hr style="border-color: #FFD700; width: 50%; margin: auto;">
    </div>

    @if (Context.Session.GetString("Especialidad") == "Entrenador General")
    {
        <a class="btn fw-bold mb-4 me-2" href="/Estudiante/Create"
           style="background:#C8102E; color:white; border-radius:12px; padding:10px 20px;">
            ➕ Nuevo Estudiante
        </a>
        <a class="btn fw-bold mb-4" href="/Estudiante/VerPagos"
           style="background:#FFD700; color:#001f8f; border-radius:12px; padding:10px 20px;">
            💰 Ver Pagos Pendientes
        </a>
    }

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-3 mb-4">
                <div class="card h-100 shadow"
                     style="border: 2px solid #FFD700; border-radius:15px; overflow:hidden; background:#1a2744; transition: transform 0.2s;"
                     onmouseover="this.style.transform='scale(1.03)'"
                     onmouseout="this.style.transform='scale(1)'">

                    <img src="@item.ImagenUrl"
                         class="card-img-top"
                         style="height:250px; width:100%; object-fit:cover; object-position:top;" />

                    <div class="card-body">
                        <h5 class="card-title fw-bold" style="color: #FFD700;">
                            @item.Nombre @item.Apellido
                        </h5>

                        <p class="card-text" style="color:#ccc;">
                            📋 <strong style="color:#FFD700;">Categoría:</strong> @item.Categoria <br />
                            📱 <strong style="color:#FFD700;">Celular:</strong> @item.Celular <br />
                            🏋️ <strong style="color:#FFD700;">Entrenador:</strong> @item.Entrenador?.Nombre @item.Entrenador?.Apellido
                        </p>

                        @if (Context.Session.GetString("Especialidad") == "Entrenador General")
                        {
                            <div class="d-flex gap-2 mb-2">
                                <a href="/Estudiante/Edit/@item.Id" class="btn btn-sm fw-bold"
                                   style="background:#FFD700; color:#001f8f; border-radius:8px;">
                                    ✏️ Editar
                                </a>
                                <a href="/Estudiante/Delete/@item.Id" class="btn btn-sm fw-bold"
                                   style="background:#C8102E; color:white; border-radius:8px;">
                                    🗑️ Eliminar
                                </a>
                            </div>
                        }

                        <hr style="border-color: #FFD700;">
                        <form asp-action="AgregarPago" method="post">
                            <input type="hidden" name="id" value="@item.Id" />
                            <select name="mes" class="form-select mb-2"
                                    style="border-radius:8px; background:#0d1b3e; color:#FFD700; border:1px solid #FFD700;">
                                <option value="Enero">Enero</option>
                                <option value="Febrero">Febrero</option>
                                <option value="Marzo">Marzo</option>
                                <option value="Abril">Abril</option>
                                <option value="Mayo">Mayo</option>
                                <option value="Junio">Junio</option>
                                <option value="Julio">Julio</option>
                                <option value="Agosto">Agosto</option>
                                <option value="Septiembre">Septiembre</option>
                                <option value="Octubre">Octubre</option>
                                <option value="Noviembre">Noviembre</option>
                                <option value="Diciembre">Diciembre</option>
                            </select>
                            <input type="number" name="monto" value="50000" min="1"
                                   class="form-control mb-2"
                                   style="border-radius:8px; background:#0d1b3e; color:#FFD700; border:1px solid #FFD700;" />
                            <button class="btn fw-bold w-100"
                                    style="background:#FFD700; color:#001f8f; border-radius:8px;">
                                💰 Registrar Pago
                            </button>
                        </form>

                    </div>
                </div>
            </div>
        }
    </div>
</div>