@model List<AcademiaFutbolSalazar.Models.Estudiante>

<div class="container mt-4">

    <h2 class="mb-4 text-center" style="color: #FFD700;">Estudiantes</h2>
    <a class="btn btn-danger mb-3" href="/Estudiante/Create">
        + Nuevo Estudiante
    </a>
    <a class="btn btn-success mb-3" href="/Estudiante/VerPagos">
        💰 Ver Pagos Pendientes
    </a>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-3 mb-4">
                <div class="card h-100 shadow bg-dark">

                    <img src="@item.ImagenUrl"
                         class="card-img-top"
                         style="height:250px; width:100%; object-fit:cover; object-position:top;" />

                    <div class="card-body">
                        <h5 class="card-title" style="color: #FFD700;">@item.Nombre @item.Apellido</h5>

                        <p class="card-text text-white">
                            Categoría: @item.Categoria <br />
                            Celular: @item.Celular <br />
                            Entrenador: @item.Entrenador?.Nombre @item.Entrenador?.Apellido
                        </p>

                        <a href="/Estudiante/Edit/@item.Id"
                           class="btn btn-warning btn-sm">Editar</a>

                        @if (Context.Session.GetString("Rol") == "Entrenador")
                        {
                            <a href="/Estudiante/Delete/@item.Id"
                               class="btn btn-danger btn-sm">Eliminar</a>
                        }

                        <hr style="border-color: #FFD700;">
                        <form asp-action="AgregarPago" method="post">
                            <input type="hidden" name="id" value="@item.Id" />
                            <input type="number" name="monto" value="50000" min="1" class="form-control mb-2 bg-dark text-white" />
                            <button class="btn btn-success btn-sm w-100">💰 Registrar Pago</button>
                        </form>

                    </div>
                </div>
            </div>
        }
    </div>
</div>