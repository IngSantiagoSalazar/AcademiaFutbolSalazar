@model AcademiaFutbolSalazar.Models.Estudiante

<div class="container mt-4 d-flex justify-content-center">
    <div class="card shadow-sm p-4"
         style="width:100%; max-width:700px; border:none; border-radius:20px; background:white;">

        <div class="text-center mb-4">
            <img src="/images/logo.png" style="width:80px;" class="mb-2" />
            <h2 class="fw-bold" style="color:#001f8f;">Crear Estudiante</h2>
            <p style="color:#666;">Registra un nuevo estudiante en la academia</p>
        </div>

        <form asp-action="Create" method="post" enctype="multipart/form-data">

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-semibold" style="color:#001f8f;">Nombre</label>
                    <input asp-for="Nombre" class="form-control" style="border-radius:12px; padding:12px;" />
                    <span asp-validation-for="Nombre" class="text-danger small"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label fw-semibold" style="color:#001f8f;">Apellido</label>
                    <input asp-for="Apellido" class="form-control" style="border-radius:12px; padding:12px;" />
                    <span asp-validation-for="Apellido" class="text-danger small"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-semibold" style="color:#001f8f;">Celular</label>
                    <input asp-for="Celular" class="form-control" style="border-radius:12px; padding:12px;" />
                    <span asp-validation-for="Celular" class="text-danger small"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label fw-semibold" style="color:#001f8f;">Fecha Nacimiento</label>
                    <input asp-for="FechaNacimiento" type="date" class="form-control" style="border-radius:12px; padding:12px;" />
                    <span asp-validation-for="FechaNacimiento" class="text-danger small"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-semibold" style="color:#001f8f;">Categoría</label>
                    <select asp-for="Categoria" class="form-select" style="border-radius:12px; padding:12px;">
                        <option value="">Seleccione una Categoría</option>
                        <option value="Sub-13">Sub-13</option>
                        <option value="Sub-15">Sub-15</option>
                        <option value="Sub-17">Sub-17</option>
                        <option value="Sub-19">Sub-19</option>
                        <option value="Sub-21">Sub-21</option>
                    </select>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label fw-semibold" style="color:#001f8f;">Entrenador</label>
                    <select asp-for="EntrenadorId" class="form-select" style="border-radius:12px; padding:12px;">
                        <option value="">Seleccione un Entrenador</option>
                        @foreach (var entrenador in ViewBag.Entrenadores)
                        {
                            <option value="@entrenador.Id">@entrenador.Nombre @entrenador.Apellido</option>
                        }
                    </select>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-semibold" style="color:#001f8f;">Clave</label>
                    <input asp-for="clave" type="password" class="form-control" style="border-radius:12px; padding:12px;" />
                    <span asp-validation-for="clave" class="text-danger small"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label fw-semibold" style="color:#001f8f;">Imagen</label>
                    <input type="file" name="imagen" class="form-control" style="border-radius:12px; padding:10px;" />
                </div>
            </div>

            <div class="mb-4 form-check">
                <input asp-for="Activo" class="form-check-input" />
                <label class="form-check-label fw-semibold ms-1" style="color:#001f8f;">Activo</label>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn fw-bold"
                        style="background:#C8102E; color:white; border-radius:12px; padding:10px 18px;">
                    💾 Guardar
                </button>
                <a href="/Estudiante" class="btn fw-bold"
                   style="background:#001f8f; color:white; border-radius:12px; padding:10px 18px;">
                    ← Volver
                </a>
            </div>

        </form>
    </div>
</div>