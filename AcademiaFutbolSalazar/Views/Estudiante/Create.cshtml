@model AcademiaFutbolSalazar.Models.Estudiante

<div class="container mt-4">
    <h2 style="color: #FFD700;">Crear Estudiante</h2>
    <form asp-action="Create" method="post" enctype="multipart/form-data">
        <div asp-validation-summary="All" class="text-danger"></div>

        <div class="mb-3">
            <label style="color: #FFD700;">Nombre</label>
            <input asp-for="Nombre" class="form-control bg-dark text-white" />
            <span asp-validation-for="Nombre" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label style="color: #FFD700;">Apellido</label>
            <input asp-for="Apellido" class="form-control bg-dark text-white" />
            <span asp-validation-for="Apellido" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label style="color: #FFD700;">Fecha Nacimiento</label>
            <input asp-for="FechaNacimiento" class="form-control bg-dark text-white" type="date" />
            <span asp-validation-for="FechaNacimiento" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label style="color: #FFD700;">Celular</label>
            <input asp-for="Celular" class="form-control bg-dark text-white" />
            <span asp-validation-for="Celular" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label style="color: #FFD700;">Categoría</label>
            <select asp-for="Categoria" class="form-control bg-dark text-white">
                <option value="">Seleccione una Categoría</option>
                <option value="Sub-13">Sub-13</option>
                <option value="Sub-15">Sub-15</option>
                <option value="Sub-17">Sub-17</option>
                <option value="Sub-19">Sub-19</option>
            </select>
        </div>

        <div class="mb-3">
            <label style="color: #FFD700;">Entrenador</label>
            <select asp-for="EntrenadorId" class="form-control bg-dark text-white">
                <option value="">Seleccione un Entrenador</option>
                @foreach (var entrenador in ViewBag.Entrenadores)
                {
                    <option value="@entrenador.Id">@entrenador.Nombre @entrenador.Apellido</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label style="color: #FFD700;">Clave</label>
            <input asp-for="clave" type="password" class="form-control bg-dark text-white" />
            <span asp-validation-for="clave" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label style="color: #FFD700;">Activo</label>
            <input asp-for="Activo" class="form-check-input ms-2" type="checkbox" />
        </div>

        <div class="mb-3">
            <label style="color: #FFD700;">Imagen</label>
            <input type="file" name="imagen" class="form-control bg-dark text-white" />
        </div>

        <hr style="border-color: #FFD700;">
        <button type="submit" class="btn btn-danger">Guardar</button>
        <a href="/Estudiante" class="btn btn-secondary">Volver</a>
    </form>
</div>